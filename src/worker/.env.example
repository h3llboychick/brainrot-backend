# Rename this file to `.env` and fill in the appropriate values before running the worker.

# =============================================================================
# DATABASE CONFIGURATION (PostgreSQL)
# =============================================================================
DB_USER=postgres
DB_PASSWORD=password
DB_HOST=db
DB_PORT=5432
DB_NAME=brainrot

# =============================================================================
# REDIS CONFIGURATION (for pub/sub and caching)
# =============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# =============================================================================
# CELERY/RABBITMQ CONFIGURATION
# =============================================================================
CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672//

# =============================================================================
# MINIO CONFIGURATION (S3-Compatible Object Storage for video uploads)
# =============================================================================
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=localhost:9000  # Public-facing host for presigned URLs (host machine access)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_VIDEOS_BUCKET=videos

# =============================================================================
# ENCRYPTION (for decrypting social account credentials)
# =============================================================================
# Must match the KEK_KEY from the main application
KEK_KEY=your-kek-key-here-replace-with-64-char-hex-string

# =============================================================================
# AI SERVICE (SambaNova for script generation)
# =============================================================================
# Get API key from: https://sambanova.ai/
SAMBANOVA_API_KEY=your-sambanova-api-key
AI_MODEL=DeepSeek-R1-Distill-Llama-70B
AI_TEMPERATURE=0.8
AI_MAX_TOKENS=2048

# =============================================================================
# VOICE GENERATION (ElevenLabs for text-to-speech)
# =============================================================================
# Get API key from: https://elevenlabs.io/
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# =============================================================================
# STOCK FOOTAGE (Pexels for background videos)
# =============================================================================
# Get API key from: https://www.pexels.com/api/
PEXELS_API_KEY=your-pexels-api-key

# =============================================================================
# GOOGLE OAUTH (for YouTube publishing)
# =============================================================================
# Contact me for OAuth credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

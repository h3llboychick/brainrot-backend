# Renamed to .env in production. Copy this file to .env and fill in the values.

# =============================================================================
# DATABASE CONFIGURATION (PostgreSQL)
# =============================================================================
DB_USER=postgres
DB_PASSWORD=password
DB_HOST=db
DB_PORT=5432
DB_NAME=brainrot

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_HOST=redis
REDIS_PORT=6379

# =============================================================================
# RABBITMQ + CELERY CONFIGURATION (Message Broker)
# =============================================================================
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASSWORD=guest
CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672//

# =============================================================================
# MINIO CONFIGURATION (S3-Compatible Object Storage)
# =============================================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# =============================================================================
# JWT AUTHENTICATION
# =============================================================================
# Generate a secure random key: python -c "import secrets; print(secrets.token_hex(32)) OR use openssl rand -hex 32"
JWT_SECRET_KEY=your-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# =============================================================================
# SESSION MIDDLEWARE
# =============================================================================
# Generate a secure random key: python -c "import secrets; print(secrets.token_hex(32)) OR use openssl rand -hex 32"
SESSION_MIDDLEWARE_SECRET_KEY=your-session-secret-key
SECRET_KEY=your-general-secret-key-here

# =============================================================================
# GOOGLE OAUTH (for user authentication)
# =============================================================================
# Contact me for OAuth credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URL=http://127.0.0.1:8000/auth/google/callback
GOOGLE_FRONTEND_URL=http://127.0.0.1:8000/users/me

# =============================================================================
# YOUTUBE API (for video publishing)
# =============================================================================
# Contact me for Youtube OAuth credentials
YOUTUBE_CLIENT_SECRET_FILE_PATH=client_secrets.json
YOUTUBE_CLIENT_ID=your-youtube-client-id.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=your-youtube-client-secret
YOUTUBE_REDIRECT_URI=http://127.0.0.1:8000/accounts/youtube/callback

# =============================================================================
# EMAIL CONFIGURATION (SMTP)
# =============================================================================
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=your-email@gmail.com
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_FROM_NAME=Brainrot AI
MAIL_STARTTLS=true
MAIL_SSL_TLS=false
USE_CREDENTIALS=true
VALIDATE_CERTS=true
TEMPLATE_FOLDER=src/infrastructure/services/email/templates

# =============================================================================
# ENCRYPTION (for securing social account credentials)
# =============================================================================
# Generate KEK: python -c "import secrets; print(secrets.token_hex(32)) OR use openssl rand -hex 32"
# This is the Key Encryption Key for envelope encryption
KEK_KEY=your-kek-key

# =============================================================================
# WORKER SERVICE API KEYS
# =============================================================================
SAMBANOVA_API_KEY=your-sambanova-api-key
ELEVENLABS_API_KEY=your-elevenlabs-api-key
PEXELS_API_KEY=your-pexels-api-key
